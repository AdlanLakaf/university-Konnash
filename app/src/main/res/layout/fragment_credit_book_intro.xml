<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Share + YouTube buttons (right side in RTL) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/share_icon"
                android:background="@drawable/bg_quick_action"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:layout_margin="8dp"
                android:contentDescription="share" />

            <ImageButton
                android:id="@+id/btn_youtube"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/youtube"
                android:background="@drawable/bg_quick_action"
                android:scaleType="centerInside"
                android:padding="14dp"
                android:layout_margin="8dp"
                android:contentDescription="youtube" />

        </LinearLayout>

        <!-- Merchant info (left side in RTL) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/info_icon"
                android:contentDescription="book" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/merchant"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/cairo_semibold"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Center illustration + text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="80dp">

        <!--
            [IMAGE PLACEHOLDER]
            ic_credit_book_empty: 3D book/contacts illustration similar to cash book empty state
            Size: 180x180dp
        -->
        <ImageView
            android:id="@+id/iv_credit_empty"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/credit_book_page_image_1"
            android:contentDescription="empty credit book" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/credit_book_empty_desc"
            android:textSize="20sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/cairo"
            android:textAlignment="center"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginTop="20dp" />

        <!-- 👇 pointing hand emoji -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👇"
            android:textSize="28sp"
            android:layout_marginTop="12dp" />

        <!-- Add Client + Add Supplier buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_client_intro"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/btn_add_client"
                android:textSize="16sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/cairo_semibold"
                android:background="@drawable/bg_button_secondary"
                android:backgroundTint="@null"
                android:stateListAnimator="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_supplier_intro"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="@string/btn_add_supplier"
                android:textSize="16sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/cairo_semibold"
                android:background="@drawable/bg_button_secondary"
                android:backgroundTint="@null"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
