<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Back arrow (end = left in RTL) -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@android:drawable/ic_media_next"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="back" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/credit_book_title"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- Center illustration + text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="80dp">

        <!--
            [IMAGE PLACEHOLDER]
            ic_credit_book_empty: 3D book/contacts illustration similar to cash book empty state
            Size: 180x180dp
        -->
        <ImageView
            android:id="@+id/iv_credit_empty"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_onboarding_clients"
            android:contentDescription="empty credit book" />

        <TextView
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:text="@string/credit_book_empty_desc"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/cairo"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginTop="20dp" />

        <!-- Add Client button -->
        <Button
            android:id="@+id/btn_add_client_intro"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_add_client"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="@font/cairo_semibold"
            android:background="@drawable/bg_button_primary"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:foreground="@drawable/ripple_white" />

    </LinearLayout>

</LinearLayout>
