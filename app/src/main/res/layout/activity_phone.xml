<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingHorizontal="40dp"
    android:paddingVertical="@dimen/screen_padding"
    android:layoutDirection="rtl">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enter_phone"
        android:textSize="22sp"
        android:textColor="@color/primary_blue"
        android:fontFamily="@font/cairo_bold"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginTop="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="36dp"
        android:gravity="bottom">

        <!-- Phone Input Section (Right) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/phone_hint"
                android:inputType="phone"
                android:background="@null"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:fontFamily="@font/cairo"
                android:textAlignment="viewStart"
                android:paddingBottom="8dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/primary_blue" />
        </LinearLayout>

        <!-- Space between field and country -->
        <Space
            android:layout_width="16dp"
            android:layout_height="wrap_content" />

        <!-- Country Section (Left) -->
        <LinearLayout
            android:id="@+id/layout_country"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+213"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/cairo" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/arrow_down_float"
                    android:layout_marginHorizontal="4dp"
                    android:tint="@color/text_secondary" />

                <ImageView
                    android:id="@+id/iv_flag"
                    android:layout_width="32dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_flag_dz"
                    android:scaleType="centerCrop"
                    android:contentDescription="flag" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1.5dp"
                android:background="@color/primary_blue" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/cairo"
        android:gravity="center"
        android:text="@string/phone_desc"
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Continue button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_continue"
        style="@style/ButtonPrimary"
        android:stateListAnimator="@null"
        android:foreground="@drawable/ripple_white"
        android:text="@string/btn_continue"
        android:layout_marginBottom="8dp" />

    <!-- Terms text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/agree_text"
        android:textSize="11sp"
        android:textColor="@color/text_hint"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/tv_privacy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy"
            android:textSize="12sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" , "
            android:textSize="12sp"
            android:textColor="@color/text_hint" />

        <TextView
            android:id="@+id/tv_terms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_of_use"
            android:textSize="12sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo" />
    </LinearLayout>

</LinearLayout>