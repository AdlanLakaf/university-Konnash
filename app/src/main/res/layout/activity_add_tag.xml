<?xml version="1.0" encoding="utf-8"?>
<!-- activity_add_tag.xml — "Add new tag" form -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="18dp"
        android:paddingEnd="16dp">

        <!-- Close (X) button -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/blue_cross"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="close" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_tag_title"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- Form content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp">

        <!-- Name label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_name"
            android:textSize="13sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_semibold"
            android:layout_marginBottom="8dp" />

        <!-- Name row: color swatch + name input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Tag name input -->

            <!-- Color swatch (placeholder square) -->
            <EditText
                android:id="@+id/et_tag_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="1dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_field"
                android:fontFamily="@font/cairo"
                android:gravity="start|center_vertical"
                android:hint="@string/hint_name"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textAlignment="viewStart"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="15sp" />

            <View
                android:id="@+id/view_color_swatch"
                android:layout_width="52dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tag_color_swatch"
                android:layout_marginStart="5dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Confirm button pinned at bottom -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm"
        style="@style/ButtonPrimary"
        android:stateListAnimator="@null"
        android:foreground="@drawable/ripple_white"
        android:text="@string/btn_confirm"
        android:layout_margin="16dp" />

</LinearLayout>
