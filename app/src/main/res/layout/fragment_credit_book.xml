<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Back arrow -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@null"
            android:src="@android:drawable/ic_media_next"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="back" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/credit_book_title"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- Credit summary card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp"
        android:layout_margin="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/total_credit"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/cairo"
            android:gravity="start" />

        <TextView
            android:id="@+id/tv_total_credit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.00 د.ج."
            android:textSize="30sp"
            android:textColor="@color/expense_red"
            android:fontFamily="@font/cairo_bold"
            android:gravity="start"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_clients_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 عميل"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/cairo"
            android:gravity="start"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Clients label row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clients_label"
            android:textSize="15sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_semibold"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

        <!-- Add client button (small) -->
        <LinearLayout
            android:id="@+id/btn_add_client_header"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_button_primary"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_add_client"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:fontFamily="@font/cairo_semibold" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Clients RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_clients"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

</LinearLayout>
