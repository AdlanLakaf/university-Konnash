<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:layoutDirection="rtl">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/white"
            android:layout_marginTop="10dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Quick actions -->
            <LinearLayout
                xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <ImageButton
                    android:id="@+id/btn_youtube_main"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/share_icon"
                    android:background="@drawable/bg_quick_action"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="share" />

                <ImageButton
                    android:id="@+id/btn_hide"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/hide_icon"
                    android:background="@drawable/bg_quick_action"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="hide balance" />

                <ImageButton
                    android:id="@+id/btn_share_main"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:src="@drawable/youtube"
                    android:background="@drawable/bg_quick_action"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:contentDescription="youtube" />

            </LinearLayout>

            <!-- Merchant -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/info_icon"
                    android:contentDescription="book" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/merchant"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/cairo_semibold"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </RelativeLayout>
        <!-- Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <!-- Right: أخذت / أعطيت amounts -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp"
                    android:gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أخذت"
                        android:textSize="18sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/cairo"
                        android:textAlignment="viewStart" />

                    <TextView
                        android:id="@+id/tv_total_took"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 د.ج."
                        android:textSize="22sp"
                        android:layout_marginTop="-12dp"
                        android:textColor="@color/income_green"
                        android:fontFamily="@font/cairo_bold"
                        android:textAlignment="viewStart" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أعطيت"
                        android:textSize="18sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/cairo"
                        android:textAlignment="viewStart"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:id="@+id/tv_total_gave"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0 د.ج."
                        android:textSize="24sp"
                        android:layout_marginTop="-12dp"
                        android:textColor="@color/expense_red"
                        android:fontFamily="@font/cairo_bold"
                        android:textAlignment="viewStart" />

                </LinearLayout>


                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <!-- Left: action icon buttons -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="20dp"
                    >

                    <!-- تحصيل الديون -->
                    <LinearLayout
                        android:id="@+id/btn_collect"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_action_icon"
                            android:contentDescription="collect debts"
                            android:padding="14dp"
                            android:src="@drawable/bell_icon" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="تحصيل الديون"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/cairo"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- التقارير -->
                    <LinearLayout
                        android:id="@+id/btn_reports"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="12dp">

                        <ImageView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:background="@drawable/bg_action_icon"
                            android:src="@drawable/analytics_icon"
                            android:padding="14dp"
                            android:contentDescription="reports" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="التقارير"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="@font/cairo"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>



                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- العملاء (1) label -->
        <TextView
            android:id="@+id/tv_clients_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="العملاء (0)"
            android:textSize="15sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_gravity="start"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Search + filter row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <!-- Search bar -->
            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_action_icon"
                android:hint="البحث"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:fontFamily="@font/cairo"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:drawableStart="@drawable/search_icon_sized"
                android:gravity="start|center_vertical"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
            <!-- Filter -->
            <ImageView
                android:id="@+id/btn_filter"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_action_icon"
                android:src="@drawable/settings_icon"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:contentDescription="filter" />
            <!-- PDF export -->
            <ImageView
                android:id="@+id/btn_export_pdf"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_action_icon"
                android:src="@drawable/pdf_icon"
                android:padding="12dp"
                android:layout_marginStart="8dp"
                android:contentDescription="export pdf" />





        </LinearLayout>

        <!-- Clients RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_clients"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- FAB: إضافة عميل — bottom start (left in RTL = left side of screen) -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_client"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="إضافة عميل"
        android:textColor="@color/white"
        android:fontFamily="@font/cairo_semibold"
        android:textSize="15sp"
        app:icon="@drawable/add_client_icon"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary_blue"
        app:iconGravity="textStart"
        app:elevation="6dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>