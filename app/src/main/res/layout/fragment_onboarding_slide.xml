<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="24dp"
    android:layoutDirection="rtl">

    <!--
        [IMAGE PLACEHOLDER]
        Each slide has a different illustration:
        Slide 1: ic_onboarding_welcome  → merchant illustration (Image 8)
        Slide 2: ic_onboarding_debts    → two hands with phone showing payments (Image 7)
        Slide 3: ic_onboarding_clients  → phone with client list (Image 12)
        Slide 4: ic_onboarding_remind   → whatsapp notification reminder (Image 13)
        Slide 5: ic_onboarding_photo    → hand with phone showing receipt (Image 6)
        All images should be ~280dp tall, placed in /res/drawable/
    -->
    <ImageView
        android:id="@+id/iv_slide_image"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:layout_marginTop="40dp"
        android:scaleType="fitCenter"
        android:contentDescription="onboarding illustration" />

    <!-- Text block centered between image and bottom dots -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp">

        <TextView
            android:id="@+id/tv_slide_title"
            style="@style/TextTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
             />

        <TextView
            android:id="@+id/tv_slide_desc"
            style="@style/TextBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#7e9cb4"
            android:textSize="22sp" />

    </LinearLayout>

</LinearLayout>
