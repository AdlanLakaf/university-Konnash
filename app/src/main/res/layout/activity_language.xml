<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="@dimen/screen_padding"
    android:layoutDirection="ltr">

    <!-- Language icon -->
    <ImageView
        android:id="@+id/iv_language_icon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_language_placeholder"
        android:scaleType="fitCenter"
        android:contentDescription="language icon" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
         />

    <!-- Language Grid 2x2 — row1: English | Turkish, row2: Arabic | French -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_turkish"
                style="@style/LanguageButton"
                android:stateListAnimator="@null"
                android:foreground="@drawable/ripple_white"
                android:text="@string/turkish"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_english"
                style="@style/LanguageButton"
                android:stateListAnimator="@null"
                android:foreground="@drawable/ripple_white"
                android:text="@string/english"
             />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_french"
                style="@style/LanguageButton"
                android:stateListAnimator="@null"
                android:foreground="@drawable/ripple_white"
                android:text="@string/french" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_arabic"
                style="@style/LanguageButton"
                android:stateListAnimator="@null"
                android:foreground="@drawable/ripple_white"
                android:text="@string/arabic" />

        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Confirm button -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm"
        style="@style/ButtonPrimary"
        android:stateListAnimator="@null"
        android:text="@string/confirm"
        android:visibility="gone"
        android:foreground="@drawable/ripple_white"
        android:layout_marginBottom="16dp" />

</LinearLayout>