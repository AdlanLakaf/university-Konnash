<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:padding="@dimen/screen_padding"
    android:layoutDirection="rtl">

    <!-- Language icon -->
    <!--
        [IMAGE PLACEHOLDER]
        Add ic_language drawable: blue speech bubble with "A" and Arabic "ض"
        Reference screenshot: Image 5 / Image 9
    -->
    <ImageView
        android:id="@+id/iv_language_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_language_placeholder"
        android:contentDescription="language icon" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Language Grid 2x2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_arabic"
                style="@style/LanguageButton"
                android:text="@string/arabic" />

            <Button
                android:id="@+id/btn_english"
                style="@style/LanguageButton"
                android:text="@string/english" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <Button
                android:id="@+id/btn_french"
                style="@style/LanguageButton"
                android:text="@string/french" />

            <Button
                android:id="@+id/btn_turkish"
                style="@style/LanguageButton"
                android:text="@string/turkish" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Confirm button (hidden until language selected) -->
    <Button
        android:id="@+id/btn_confirm"
        style="@style/ButtonPrimary"
        android:text="@string/confirm"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

</LinearLayout>
