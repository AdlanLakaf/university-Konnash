<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Back / forward arrow (end = left in RTL) -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_previous"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="back" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_client_title"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- ── Name field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_name"
                android:textSize="13sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/cairo_semibold"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/hint_name"
                android:background="@drawable/bg_input_field"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:fontFamily="@font/cairo"
                android:gravity="center_vertical|end"
                android:textAlignment="viewStart"
                android:inputType="textPersonName"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- ── Phone field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_phone"
                android:textSize="13sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/cairo_semibold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- Phone row: country selector + input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Phone number input -->
                <EditText
                    android:id="@+id/et_phone"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_phone"
                    android:background="@drawable/bg_input_field"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:fontFamily="@font/cairo"
                    android:gravity="start|center_vertical"
                    android:textAlignment="viewStart"
                    android:inputType="phone"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <!-- Country code box -->
                <LinearLayout
                    android:id="@+id/layout_country_code"
                    android:layout_marginStart="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_input_field"
                    android:paddingStart="8dp"
                    android:paddingEnd="25dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+213"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/cairo"
                        android:layout_marginStart="4dp" />

                    <ImageView
                        android:paddingRight="5dp"
                        android:layout_width="28dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_flag_dz"
                        android:scaleType="centerCrop"
                        android:contentDescription="flag" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── Address field ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_address"
                android:textSize="13sp"
                android:textColor="@color/primary_blue"
                android:fontFamily="@font/cairo_semibold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp" />

            <!-- Address row: input + location icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                >

                <!-- Address input -->
                <EditText
                    android:id="@+id/et_address"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_address"
                    android:background="@drawable/bg_input_field"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:fontFamily="@font/cairo"
                    android:gravity="start|center_vertical"
                    android:textAlignment="viewStart"
                    android:inputType="textPostalAddress"
                    android:paddingStart="12dp"
                    android:paddingEnd="-15dp"
                    android:drawableEnd="@drawable/ic_next"
                    android:drawablePadding="8dp"
                    />


            </LinearLayout>

            <!-- ── Tags section ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_tag_section"
                android:layout_marginTop="20dp"
                android:padding="14dp">

                <!-- Tags header row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Tags label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_tags"
                        android:textSize="16sp"
                        android:textColor="@color/primary_blue"
                        android:fontFamily="@font/cairo_semibold"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true" />

                    <!-- Manage tags button -->
                    <LinearLayout
                        android:id="@+id/btn_manage_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_tag_chip"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true">


                        <TextView
                            android:id="@+id/tv_manage_tags_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/btn_add_tags"
                            android:textSize="12sp"
                            android:textColor="@color/primary_blue"
                            android:fontFamily="@font/cairo_semibold" />

                    </LinearLayout>

                </RelativeLayout>

                <!-- Selected tags FlexboxLayout (simulated with HorizontalScrollView + LinearLayout) -->
                <HorizontalScrollView
                    android:id="@+id/hsv_selected_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/ll_selected_tags"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layoutDirection="rtl" />

                </HorizontalScrollView>

                <!-- Hint text shown when no tags selected -->
                <TextView
                    android:id="@+id/tv_tags_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tags_hint"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="@font/cairo"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Confirm button pinned at bottom -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_confirm"
        style="@style/ButtonPrimary"
        android:stateListAnimator="@null"
        android:foreground="@drawable/ripple_white"
        android:text="@string/btn_confirm_client"
        android:layout_margin="16dp" />

</LinearLayout>
