<?xml version="1.0" encoding="utf-8"?>
<!-- activity_add_client_entry.xml  — First screen: two options (add manually / import) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layoutDirection="rtl">

    <!-- Top bar -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:background="@null"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_previous"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_client_title"
            android:textSize="18sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo_bold"
            android:layout_centerInParent="true" />

    </RelativeLayout>

    <!-- Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp">

        <!-- Add new client manually -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_add_new_client"
            style="@style/ButtonPrimary"
            android:stateListAnimator="@null"
            android:foreground="@drawable/ripple_white"
            android:text="@string/btn_add_new_client" />

        <!-- Import from contacts -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_import_contacts"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_import_contacts"
            android:textSize="16sp"
            android:textColor="@color/primary_blue"
            android:fontFamily="@font/cairo"
            android:background="@drawable/bg_button_secondary"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:gravity="center" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/import_contacts_desc"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="@font/cairo"
            android:textAlignment="center"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</LinearLayout>
